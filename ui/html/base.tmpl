{{define "base"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{template "title" .}} | FilmGap</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/static/css/style.css?v=2.0">
    {{block "head" .}}{{end}}
</head>
<body class="d-flex flex-column min-vh-100 font-system">
    
    <!-- 100% Width Header -->
    <header class="global-header w-100">
        {{template "nav" .}}
    </header>
    
    <!-- Main Content Area bounded to 1600px -->
    <!-- The padding: 20px is handled by the main-wrapper css class -->
    <main class="main-wrapper mx-auto flex-grow-1 w-100">
        {{template "main" .}}
    </main>

    <!-- 100% Width Footer -->
    <footer class="global-footer w-100 mt-auto">
        <div class="container-1600 mx-auto w-100 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <p class="mb-0 small">&copy; 2026 FilmGap. All rights reserved.</p>
            <ul class="list-inline mb-0 small">
                <li class="list-inline-item"><a href="/about" class="text-decoration-none text-white-50 hover-white">About</a></li>
                <li class="list-inline-item ms-3"><a href="/privacy" class="text-decoration-none text-white-50 hover-white">Privacy Policy</a></li>
                <li class="list-inline-item ms-3"><a href="/terms" class="text-decoration-none text-white-50 hover-white">Terms of Service</a></li>
            </ul>
        </div>
    </footer>

    {{template "interaction_modal" .}}

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/static/js/main.js"></script>
    {{block "scripts" .}}{{end}}
</body>
</html>
{{end}}
