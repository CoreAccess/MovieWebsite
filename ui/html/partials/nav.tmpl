{{define "nav"}}
<div class="container-1600 mx-auto d-flex align-items-center h-100 w-100">
    
    <!-- Left: Logo -->
    <a class="navbar-brand d-flex align-items-center fw-bold fs-4 text-dark text-decoration-none me-4" href="/">
        <span>Film Gap</span>
    </a>

    <!-- Center-Left: Nav Links (Full Height) -->
    <nav class="d-none d-lg-flex h-100 me-auto">
        <a href="/movies" class="nav-link-custom active">Movies</a>
        <a href="/tv-shows" class="nav-link-custom">TV Shows</a>
        <a href="/people" class="nav-link-custom">People</a>
        <a href="/blog" class="nav-link-custom">Blog</a>
    </nav>

    <!-- Center-Right: Search Bar -->
    <form class="d-none d-md-flex mx-4 flex-grow-1 header-search" action="/search" method="GET">
        <div class="input-group">
            <span class="input-group-text bg-light"><i class="bi bi-search text-muted"></i></span>
            <input type="search" name="q" class="form-control bg-light shadow-none px-2 py-2" placeholder="Search for movies, tv shows, people..." aria-label="Search">
        </div>
    </form>

    <!-- Right: Auth Buttons -->
    <div class="d-flex align-items-center gap-3 ms-auto">
        {{if .AuthenticatedUser}}
        <a href="/notifications" class="text-dark position-relative hover-lift" title="Notifications">
            <i class="bi bi-bell fs-5"></i>
            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle" style="width: 8px; height: 8px;">
                <span class="visually-hidden">New alerts</span>
            </span>
        </a>
        <!-- Authenticated Dropdown using existing logic roughly -->
        <div class="dropdown">
            <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <img src="{{if .AuthenticatedUser.Avatar}}{{.AuthenticatedUser.Avatar}}{{else}}https://placehold.co/100x100/e2e8f0/64748b?text={{.AuthenticatedUser.Username}}{{end}}" alt="User" class="rounded-circle" width="32" height="32" style="object-fit:cover;">
                <span class="d-none d-md-inline">{{.AuthenticatedUser.Username}}</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                <li><a class="dropdown-item py-2 fw-medium" href="/profile">My Profile</a></li>
                <li><a class="dropdown-item py-2 fw-medium" href="/lists">My Lists</a></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form action="/logout" method="POST">
                        <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                        <button type="submit" class="dropdown-item py-2 fw-medium text-danger">Sign Out</button>
                    </form>
                </li>
            </ul>
        </div>
        {{else}}
        <!-- Guest Auth Buttons -->
        <a href="/login" class="btn btn-outline-secondary fw-bold border-0 text-dark px-3 hover-lift">Log In</a>
        <a href="/signup" class="btn btn-primary fw-bold px-4 rounded-1 hover-lift">Sign Up</a>
        {{end}}
    </div>
</div>
{{end}}
