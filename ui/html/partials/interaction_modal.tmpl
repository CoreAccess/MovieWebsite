{{define "interaction_modal"}}
<!-- Interaction Modal -->
<div class="modal fade" id="interactionModal" tabindex="-1" aria-labelledby="interactionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-1 border-0 shadow-lg">
            <form id="interactionForm" action="/review" method="POST">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <input type="hidden" name="media_id" id="modalMediaId">
                <input type="hidden" name="media_type" id="modalMediaType">
                
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="interactionModalLabel">Log Media</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <div class="modal-body py-4">
                    <!-- Rating Scale 1-10 -->
                    <div class="mb-4">
                        <label class="form-label d-block fw-bold small text-muted text-uppercase mb-3">Your Rating</label>
                        <div class="d-flex justify-content-between gap-1 rating-group">
                            {{range $i := seq 1 10}}
                            <input type="radio" class="btn-check" name="rating" id="rate-{{$i}}" value="{{$i}}" autocomplete="off">
                            <label class="btn btn-outline-primary flex-grow-1 p-2 rounded-1 fw-bold" for="rate-{{$i}}">{{$i}}</label>
                            {{end}}
                        </div>
                    </div>

                    <!-- Review Text -->
                    <div class="mb-4">
                        <label for="reviewBody" class="form-label fw-bold small text-muted text-uppercase mb-2">Write a Review (Optional)</label>
                        <textarea class="form-control border-subtle rounded-1 p-3" id="reviewBody" name="content" rows="4" placeholder="What did you think?"></textarea>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" name="is_spoiler" value="true" id="spoilerCheck">
                        <label class="form-check-label fw-medium" for="spoilerCheck">
                            Contains Spoilers
                        </label>
                    </div>

                    <!-- Add to List -->
                    <div class="mb-2 border-top pt-4">
                        <label for="listSelect" class="form-label fw-bold small text-muted text-uppercase mb-2">Add to Collection</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-subtle"><i class="bi bi-list-stars"></i></span>
                            <select class="form-select border-subtle rounded-end-1" name="list_id" id="listSelect">
                                <option value="">Select a list...</option>
                                {{range .Lists}}
                                <option value="{{.ID}}">{{.Name}}</option>
                                {{end}}
                            </select>
                        </div>
                        {{if not .Lists}}
                        <div class="form-text extra-small mt-1">
                            You don't have any lists yet. <a href="/list/create" class="text-primary">Create one</a>.
                        </div>
                        {{end}}
                    </div>
                </div>
                
                <div class="modal-footer border-0 pt-0 d-flex justify-content-between">
                    <button type="button" id="modalWatchlistBtn" class="btn btn-outline-dark border-subtle rounded-1 px-4 d-flex align-items-center gap-2">
                        <i class="bi bi-bookmark-plus"></i> Watchlist
                    </button>
                    <button type="submit" class="btn btn-primary rounded-1 px-5 fw-bold">Save Log</button>
                </div>
            </form>
        </div>
    </div>
</div>
{{end}}
